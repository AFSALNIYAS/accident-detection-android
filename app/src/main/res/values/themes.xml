<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Accidentdetection3" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:textCursorDrawable">@drawable/cursor_red</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.Accidentdetection3" parent="Base.Theme.Accidentdetection3" />

    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.App.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="strokeColor">@color/stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Splash / full-screen dark theme -->
    <style name="Theme.Accidentdetection3.Splash" parent="Theme.Accidentdetection3">
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <!-- Theme overlay that forces red cursor in TextInputLayout -->
    <style name="ThemeOverlay.App.RedCursor" parent="">
        <item name="colorControlActivated">@color/accent</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="android:textCursorDrawable">@drawable/cursor_red</item>
    </style>
</resources>
